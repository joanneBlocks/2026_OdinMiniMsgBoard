<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
</head>
<body>
  <h1><%= title %></h1>

  <a href="/new">Add New Message</a>

  <ul>
    <% messages.forEach((msg, index) => { %>
      <li>
        <strong><%= msg.user %></strong>: <%= msg.text %> <br>
        <small><%= msg.added %></small><br>

        <a href="/message/<%= index %>">Open</a>
      </li>
    <% }) %>
  </ul>
</body>
</html>